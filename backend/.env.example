# Copy this file to `.env` and fill in real values for local dev.
# pydantic-settings (in app/config.py) reads these automatically.
# `.env` is in .gitignore — never commit it.

# Which environment we're running in. Affects log verbosity etc.
APP_ENV=development

# Origins allowed to call the API (your Vite frontend).
# Comma-separated. Vite default is 5173.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Where the database file lives. Default is fine for local dev.
DATABASE_URL=sqlite:///./mai_coach.db
